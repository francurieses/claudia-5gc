+//
+// 5GC Rel-17 modification — LPP A-GNSS UE responder (TS 37.355 subset, LMF-009).
+//
+// Adds UE-side handling of the LTE Positioning Protocol (LPP) carried in a
+// DL NAS TRANSPORT with payload container type "LPP message container" (0x03),
+// per TS 24.501 §8.7.4 / §9.11.3.40. Stock UERANSIM v3.2.8 has no LPP support
+// and logs "Unhandled payload container type [3]".
+//
+// The wire format is ASN.1 BASIC-PER UNALIGNED (X.691) as TS 37.355 §4
+// mandates. This file hand-rolls the same unaligned-PER bit codec as the 5GC
+// Go encoder in shared/lpp (uper.go + lpp.go) and mirrors the deterministic
+// GNSS geometry in shared/lpp/gnss.go — Go is the source of truth
+// (tools/ueransim/CLAUDE.md §4); the UL encoders below byte-match the Go
+// package's golden-hex test dumps (shared/lpp/lpp_test.go).
+//
+// Message subset (docs/procedures/LPPRelay.md — the LMF-009 wire contract):
+//   DL  RequestCapabilities          -> UL ProvideCapabilities (echo txn)
+//   DL  ProvideAssistanceData        -> (no reply; reference location stored)
+//   DL  RequestLocationInformation   -> UL ProvideLocationInformation
+//                                        (4 synthetic GNSS-SatMeasElement, or
+//                                         gnss-Error when no anchor stored)
+//
+
+#pragma once
+
+#include <cstddef>
+#include <cstdint>
+#include <optional>
+#include <string>
+#include <vector>
+
+namespace nr::ue::lpp
+{
+
+// ---- Message type discriminators (local, not wire bytes) ---------------------
+
+constexpr uint8_t MsgRequestCapabilities = 1;
+constexpr uint8_t MsgProvideCapabilities = 2;
+constexpr uint8_t MsgProvideAssistanceData = 3;
+constexpr uint8_t MsgRequestLocationInformation = 4;
+constexpr uint8_t MsgProvideLocationInformation = 5;
+
+// ---- Transaction handling (TS 37.355 §5.2) ------------------------------------
+
+// LPP-TransactionID.initiator (extensible ENUMERATED {locationServer(0),
+// targetDevice(1), ...}). The UE always ECHOES the LMF-assigned transaction.
+constexpr uint8_t InitiatorLocationServer = 0;
+constexpr uint8_t InitiatorTargetDevice = 1;
+
+struct TransactionID
+{
+    uint8_t initiator = 0;
+    uint8_t number = 0; // TransactionNumber ::= INTEGER (0..255)
+};
+
+// ---- GNSS-TargetDeviceErrorCauses.cause root values (TS 37.355 §6.5.2) --------
+
+constexpr uint8_t GnssErrorUndefined = 0;
+constexpr uint8_t GnssErrorNotEnoughSatellites = 1;
+constexpr uint8_t GnssErrorAssistanceDataMissing = 2;
+
+// ---- Wire-contract pinned per-SV values (docs/procedures/LPPRelay.md) ---------
+
+constexpr uint8_t CNoDefault = 44;               // dB-Hz
+constexpr uint8_t MpathDetLow = 1;               // mpathDet ENUM low(1)
+constexpr uint8_t CodePhaseRMSErrorDefault = 20; // k=8y+x => x=4,y=2 => 3.0 m
+
+// ---- Synthetic-UE model constants (mirror shared/lpp/gnss.go) ------------------
+
+constexpr double UEOffsetNorthM = 25.0; // synthetic true position offset from anchor
+constexpr double UEOffsetEastM = 15.0;
+constexpr double UEClockBiasM = 150.0; // receiver clock bias (metres of range)
+
+// ---- Pseudorange / GPS time constants (TS 37.355 §6.5.2) -----------------------
+
+constexpr double MetersPerMsOfRange = 299792.458;   // c x 1 ms
+constexpr double CodePhaseUnitsPerMs = 2097152.0;   // 2^21 codePhase units per ms
+constexpr int64_t GpsEpochUnix = 315964800;         // 1980-01-06T00:00:00Z
+constexpr int64_t GpsUtcLeapSeconds = 18;           // documented implementation constant
+
+// ---- Decoded / builder value types ---------------------------------------------
+
+// EllipsoidPointWithAltitudeAndUncertaintyEllipsoid raw wire values
+// (TS 23.032 §6 quantization — see DecodeLatitude/DecodeLongitude).
+struct ReferenceLocation
+{
+    uint8_t latitudeSign = 0;      // 0 = north, 1 = south
+    uint32_t degreesLatitude = 0;  // 0..8388607 (23-bit)
+    int32_t degreesLongitude = 0;  // -8388608..8388607 (24-bit)
+    uint8_t altitudeDirection = 0; // 0 = height, 1 = depth
+    uint16_t altitude = 0;         // 0..32767 metres
+    uint8_t uncertaintySemiMajor = 0;
+    uint8_t uncertaintySemiMinor = 0;
+    uint8_t orientationMajorAxis = 0;
+    uint8_t uncertaintyAltitude = 0;
+    uint8_t confidence = 0;
+};
+
+// Decoded leg-2 ProvideAssistanceData payload (gnss-ReferenceTime +
+// gnss-ReferenceLocation) — the stored anchor that seeds the synthetic
+// constellation on the leg-3 reply.
+struct AssistanceData
+{
+    uint16_t dayNumber = 0;       // gnss-DayNumber INTEGER (0..32767)
+    uint32_t timeOfDay = 0;       // gnss-TimeOfDay INTEGER (0..86399)
+    uint8_t referenceTimeUnc = 0; // referenceTimeUnc INTEGER (0..127)
+    ReferenceLocation referenceLocation{};
+};
+
+// One GNSS-SatMeasElement (the fields this subset carries).
+struct SatMeas
+{
+    uint8_t svid = 0;              // SV-ID.satellite-id 0..63 (constellation index - 1)
+    uint8_t cno = 0;               // 0..63 dB-Hz
+    uint8_t mpathDet = 0;          // ENUM index (root)
+    uint32_t codePhase = 0;        // 0..2097151, 2^-21 ms units
+    uint8_t integerCodePhase = 0;  // 0..127 whole ms (always included)
+    uint8_t codePhaseRMSError = 0; // 0..63
+};
+
+// Leg-3 UL measurement payload (gnss-SignalMeasurementInformation).
+struct LocationMeasurements
+{
+    uint32_t gnssTODMsec = 0; // measurementReferenceTime.gnss-TOD-msec (0..3599999)
+    std::vector<SatMeas> sats;
+};
+
+// Decoded DL LPP-Message. `type` selects the message kind; assistanceData is
+// set only for ProvideAssistanceData. (The UE only ever receives the 3 DL
+// messages of the contract; UL bodies decode as an error.)
+struct Pdu
+{
+    uint8_t type = 0;
+    bool hasTransactionID = false;
+    TransactionID transactionID{};
+    bool endTransaction = false;
+    std::optional<AssistanceData> assistanceData{};
+};
+
+// ---- Codec (mirror of shared/lpp/lpp.go — byte-compatible) ---------------------
+
+// Decode raw UPER LPP-Message bytes (the NAS payload container value, PCT 0x03).
+// Returns true on success; on failure returns false and sets `error`.
+// Extension additions set by a future peer on any extensible SEQUENCE are
+// skipped (X.691 §19.7-19.9 open-type skip), matching the Go decoder.
+bool Decode(const uint8_t *data, size_t len, Pdu &out, std::string &error);
+
+// Build the leg-1 UL ProvideCapabilities, echoing txn with endTransaction=TRUE.
+// gnssSupported=true: one GNSS-SupportElement {gps, ue-assisted, GPS L1 C/A}.
+// gnssSupported=false (LPP_GNSS_NONE): a-gnss-ProvideCapabilities absent.
+std::vector<uint8_t> BuildProvideCapabilities(const TransactionID &txn, bool gnssSupported);
+
+// Build the leg-3 UL ProvideLocationInformation, echoing txn with
+// endTransaction=TRUE (1..64 satellites; this UE sends 4). Inputs must be in
+// range (guaranteed by the synthetic model); out-of-range values are clamped.
+std::vector<uint8_t> BuildProvideLocationInformation(const TransactionID &txn, const LocationMeasurements &meas);
+
+// Build a ProvideLocationInformation carrying gnss-Error.targetDeviceErrorCauses
+// {cause} instead of measurements (e.g. assistanceDataMissing when no anchor).
+std::vector<uint8_t> BuildProvideLocationInformationError(const TransactionID &txn, uint8_t cause);
+
+// ---- GNSS math (mirror of shared/lpp/gnss.go — same formulas, double math) -----
+
+// A per-satellite synthetic ephemeris entry (ECEF metres). svid is the 1-based
+// constellation index; it rides the wire as SV-ID.satellite-id = svid - 1.
+struct SatEphemeris
+{
+    uint8_t svid = 0;
+    double x = 0, y = 0, z = 0;
+};
+
+// TS 23.032 §6 dequantization — the quantized-anchor rule: both ends seed the
+// synthetic geometry with THESE decoded degrees, never the pristine config floats.
+double DecodeLatitude(uint8_t sign, uint32_t raw); // raw * 90 / 2^23, negated for south
+double DecodeLongitude(int32_t raw);               // raw * 360 / 2^24
+
+// WGS84 geodetic (degrees, metres) -> ECEF (metres).
+void GeodeticToECEF(double latDeg, double lonDeg, double altM, double &x, double &y, double &z);
+
+// Deterministic 4-satellite constellation around the (quantized) anchor:
+// (elev, az) = {75,0} {60,90} {45,200} {30,300} at 22,000 km slant range.
+std::vector<SatEphemeris> GenerateSyntheticEphemeris(double anchorLatDeg, double anchorLonDeg);
+
+// Displace a WGS84 point by (northM, eastM) metres via the local ENU frame.
+void OffsetGeodetic(double latDeg, double lonDeg, double northM, double eastM, double &outLatDeg, double &outLonDeg);
+
+// Pseudorange (metres) -> wire (integerCodePhase, codePhase). Returns false when
+// the pseudorange exceeds the integerCodePhase range (> 127 ms) or is negative.
+bool PseudorangeToCodePhase(double pseudorangeM, uint8_t &integerCodePhase, uint32_t &codePhase);
+
+// MeasurementReferenceTime.gnss-TOD-msec (0..3599999) — ms into the current GPS hour.
+uint32_t GpsTodMsec(int64_t unixUtc, int msec);
+
+// GpsTodMsec for the current wall clock.
+uint32_t GpsTodMsecNow();
+
+} // namespace nr::ue::lpp
