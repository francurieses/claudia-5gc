+// 5GC Rel-17 mod: LPP A-GNSS responder (TS 37.355, docs/procedures/LPPRelay.md,
+// LMF-009). The UE answers the three DL LPP legs the LMF relays over N1
+// (TS 23.273 §7.2): RequestCapabilities -> ProvideCapabilities;
+// ProvideAssistanceData -> store the wire-quantized reference location (no
+// reply — unsolicited); RequestLocationInformation -> ProvideLocationInformation
+// with 4 synthetic GNSS-SatMeasElement pseudoranges derived from the stored
+// anchor (C++ mirror of shared/lpp/gnss.go — Go is the source of truth).
+void NasMm::receiveLppMessage(const OctetString &container)
+{
+    lpp::Pdu pdu;
+    std::string err;
+    if (!lpp::Decode(container.data(), static_cast<size_t>(container.length()), pdu, err))
+    {
+        m_logger->err("LPP: failed to decode DL LPP message: %s", err.c_str());
+        return;
+    }
+
+    switch (pdu.type)
+    {
+    case lpp::MsgRequestCapabilities: {
+        // Negative mode: LPP_GNSS_NONE=1 reports GNSS unsupported so the LMF
+        // falls back to E-CID/Cell-ID (TS 23.273 §6.2.10) with no 5xx.
+        const char *none = std::getenv("LPP_GNSS_NONE");
+        bool gnssNone = none != nullptr && none[0] == '1' && none[1] == '\0';
+        if (gnssNone)
+            m_logger->info("LPP: GNSS disabled (LPP_GNSS_NONE) -> ProvideCapabilities without GNSS");
+        else
+            m_logger->info("LPP RequestCapabilities received -> ProvideCapabilities (GNSS supported)");
+        sendLppMessage(lpp::BuildProvideCapabilities(pdu.transactionID, !gnssNone));
+        break;
+    }
+    case lpp::MsgProvideAssistanceData: {
+        // Unsolicited assistance delivery — TS 37.355 has no response message.
+        m_lppAssistance = pdu.assistanceData;
+        m_logger->info("LPP ProvideAssistanceData received (reference location stored)");
+        break;
+    }
+    case lpp::MsgRequestLocationInformation: {
+        if (!m_lppAssistance.has_value())
+        {
+            m_logger->warn("LPP RequestLocationInformation received with no stored assistance data -> gnss-Error");
+            sendLppMessage(
+                lpp::BuildProvideLocationInformationError(pdu.transactionID, lpp::GnssErrorAssistanceDataMissing));
+            break;
+        }
+        sendLppLocationInformation(pdu.transactionID);
+        break;
+    }
+    default:
+        m_logger->warn("LPP: unhandled DL LPP message type [%d]", static_cast<int>(pdu.type));
+        break;
+    }
+}
+
+// Compute the leg-3 synthetic GNSS measurements and send ProvideLocationInformation.
+// Quantized-anchor rule: the constellation is seeded with the lat/lon DECODED
+// from the wire (raw*90/2^23, raw*360/2^24), so LMF and UE derive byte-identical
+// geometry. UE true position = anchor +25 m N +15 m E; every pseudorange carries
+// a +150 m receiver clock bias that the LMF's WLS solves out.
+void NasMm::sendLppLocationInformation(const lpp::TransactionID &txn)
+{
+    const auto &loc = m_lppAssistance->referenceLocation;
+    double anchorLat = lpp::DecodeLatitude(loc.latitudeSign, loc.degreesLatitude);
+    double anchorLon = lpp::DecodeLongitude(loc.degreesLongitude);
+
+    auto ephemeris = lpp::GenerateSyntheticEphemeris(anchorLat, anchorLon);
+
+    double trueLat, trueLon;
+    lpp::OffsetGeodetic(anchorLat, anchorLon, lpp::UEOffsetNorthM, lpp::UEOffsetEastM, trueLat, trueLon);
+    double ux, uy, uz;
+    lpp::GeodeticToECEF(trueLat, trueLon, 0.0, ux, uy, uz);
+
+    lpp::LocationMeasurements meas{};
+    meas.gnssTODMsec = lpp::GpsTodMsecNow();
+    for (const auto &sat : ephemeris)
+    {
+        double dx = ux - sat.x, dy = uy - sat.y, dz = uz - sat.z;
+        double pseudorange = std::sqrt(dx * dx + dy * dy + dz * dz) + lpp::UEClockBiasM;
+
+        lpp::SatMeas sv{};
+        if (!lpp::PseudorangeToCodePhase(pseudorange, sv.integerCodePhase, sv.codePhase))
+        {
+            m_logger->warn("LPP: pseudorange %.1f m exceeds integerCodePhase range -> gnss-Error", pseudorange);
+            sendLppMessage(lpp::BuildProvideLocationInformationError(txn, lpp::GnssErrorNotEnoughSatellites));
+            return;
+        }
+        sv.svid = static_cast<uint8_t>(sat.svid - 1); // SV-ID.satellite-id = constellation index - 1
+        sv.cno = lpp::CNoDefault;
+        sv.mpathDet = lpp::MpathDetLow;
+        sv.codePhaseRMSError = lpp::CodePhaseRMSErrorDefault;
+        meas.sats.push_back(sv);
+    }
+
+    m_logger->info("LPP RequestLocationInformation received -> ProvideLocationInformation (%d satellites)",
+                   static_cast<int>(meas.sats.size()));
+    sendLppMessage(lpp::BuildProvideLocationInformation(txn, meas));
+}
+
+// Wrap a UL LPP message in an UL NAS Transport with payload container type
+// "LPP message container" (0x03) — TS 24.501 §8.7.4 / §9.11.3.40.
+void NasMm::sendLppMessage(const std::vector<uint8_t> &lppPdu)
+{
+    nas::UlNasTransport ul;
+    ul.payloadContainerType.payloadContainerType = nas::EPayloadContainerType::LPP_MESSAGE;
+    for (uint8_t b : lppPdu)
+        ul.payloadContainer.data.appendOctet(b);
+
+    deliverUlTransport(ul, ENasTransportHint::LPP_TRANSPORT);
+}
+
 } // namespace nr::ue
