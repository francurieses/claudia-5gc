+void NgapTask::receiveLocationReportingControl(int amfId, ASN_NGAP_LocationReportingControl *msg)
+{
+    // 5GC Rel-17 mod: answer an AMF-initiated Location Reporting Control (TS 38.413 §8.17.2)
+    // with a Location Report carrying the serving cell. Stock UERANSIM has no handler for this,
+    // so without this patch the LMF DetermineLocation flow stalls at the gNB.
+    m_logger->debug("Location Reporting Control received");
+
+    auto *ue = findUeByNgapIdPair(amfId, ngap_utils::FindNgapIdPair(msg));
+    if (ue == nullptr)
+        return;
+
+    // Read the requested reporting type. We support EventType=Direct (a single immediate report);
+    // periodic / area-of-interest / change-of-serving-cell are not implemented — we still emit one
+    // report and warn, which keeps the on-demand Cell-ID positioning flow working.
+    long eventType = ASN_NGAP_EventType_direct;
+    long reportArea = ASN_NGAP_ReportArea_cell;
+    auto *ieReqType = asn::ngap::GetProtocolIe(msg, ASN_NGAP_ProtocolIE_ID_id_LocationReportingRequestType);
+    if (ieReqType != nullptr)
+    {
+        eventType = ieReqType->LocationReportingRequestType.eventType;
+        reportArea = ieReqType->LocationReportingRequestType.reportArea;
+        if (eventType != ASN_NGAP_EventType_direct)
+            m_logger->warn("LocationReportingControl event type [%ld] not supported; sending a single report",
+                           eventType);
+    }
+
+    // Build the Location Report. AMF-UE-NGAP-ID, RAN-UE-NGAP-ID and UserLocationInformation
+    // (serving NR-CGI + TAI + timestamp, from the gNB config) are inserted automatically by
+    // sendNgapUeAssociated; we only echo back the LocationReportingRequestType.
+    std::vector<ASN_NGAP_LocationReportIEs *> ies;
+
+    auto *ie = asn::New<ASN_NGAP_LocationReportIEs>();
+    ie->id = ASN_NGAP_ProtocolIE_ID_id_LocationReportingRequestType;
+    ie->criticality = ASN_NGAP_Criticality_ignore;
+    ie->value.present = ASN_NGAP_LocationReportIEs__value_PR_LocationReportingRequestType;
+    ie->value.choice.LocationReportingRequestType.eventType = eventType;
+    ie->value.choice.LocationReportingRequestType.reportArea = reportArea;
+    ies.push_back(ie);
+
+    auto *report = asn::ngap::NewMessagePdu<ASN_NGAP_LocationReport>(ies);
+    sendNgapUeAssociated(ue->ctxId, report);
+
+    m_logger->info("Location Report sent (cell-ID positioning)");
+}
+
 } // namespace nr::gnb
